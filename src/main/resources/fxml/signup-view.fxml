<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<HBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.wig3003.multimedia.controller.SignupController"
      stylesheets="@../css/auth.css,@../css/app.css">

    <!-- LEFT PANEL -->
    <VBox styleClass="left-panel"
          alignment="CENTER"
          spacing="15"
          HBox.hgrow="ALWAYS">

        <Label text="📷" styleClass="logo-icon"/>
        <Label text="PhotoManager" styleClass="logo-title"/>
        <Label text="Organize, manage, and cherish your memories" styleClass="logo-subtitle"/>
    </VBox>

    <!-- RIGHT PANEL -->
    <VBox styleClass="right-panel"
          alignment="CENTER"
          spacing="16"
          HBox.hgrow="ALWAYS">

        <VBox styleClass="auth-card" spacing="8" alignment="TOP_LEFT">

            <padding>
                <Insets top="25" right="30" bottom="25" left="30"/>
            </padding>

            <Label text="Create Account" styleClass="card-title"/>
            <Label text="Join PhotoManager to start organizing your photos" styleClass="card-subtitle"/>

            <!-- NAME -->
            <Label text="Name" styleClass="field-label"/>

            <HBox fx:id="nameBox" styleClass="input-box" alignment="CENTER_LEFT" spacing="10">
                <Label text="👤" styleClass="input-icon"/>
                <TextField fx:id="nameField"
                           promptText="Enter your username"
                           HBox.hgrow="ALWAYS"
                           styleClass="text-input"/>
            </HBox>

            <Label fx:id="nameError"
                   text=""
                   styleClass="error-text"
                   visible="false"
                   managed="false"/>

            <!-- EMAIL -->
            <Label text="Email" styleClass="field-label"/>

            <HBox fx:id="emailBox" styleClass="input-box" alignment="CENTER_LEFT" spacing="10">
                <Label text="✉" styleClass="input-icon"/>
                <TextField fx:id="emailField"
                           promptText="Enter your email"
                           HBox.hgrow="ALWAYS"
                           styleClass="text-input"/>
            </HBox>

            <Label fx:id="emailError"
                   text=""
                   styleClass="error-text"
                   visible="false"
                   managed="false"/>

            <!-- PASSWORD -->
            <Label text="Password" styleClass="field-label"/>

            <HBox fx:id="passwordBox" styleClass="input-box" alignment="CENTER_LEFT" spacing="10">
                <Label text="🔒" styleClass="input-icon"/>
                <PasswordField fx:id="passwordField"
                               promptText="Create password"
                               HBox.hgrow="ALWAYS"
                               styleClass="text-input"/>
            </HBox>

            <Label fx:id="passwordError"
                   text=""
                   styleClass="error-text"
                   visible="false"
                   managed="false"/>

            <!-- CONFIRM PASSWORD -->
            <Label text="Confirm Password" styleClass="field-label"/>

            <HBox fx:id="confirmBox" styleClass="input-box" alignment="CENTER_LEFT" spacing="10">
                <Label text="🔒" styleClass="input-icon"/>
                <PasswordField fx:id="confirmPasswordField"
                               promptText="Confirm password"
                               HBox.hgrow="ALWAYS"
                               styleClass="text-input"/>
            </HBox>

            <Label fx:id="confirmPasswordError"
                   text=""
                   styleClass="error-text"
                   visible="false"
                   managed="false"/>

            <Button text="Sign Up"
                    onAction="#signup"
                    styleClass="primary-btn"
                    maxWidth="Infinity"/>

            <Label fx:id="statusLabel" styleClass="status-text"/>

            <HBox alignment="CENTER" spacing="5">
                <Label text="Already have an account?" styleClass="bottom-text"/>
                <Hyperlink text="Login" onAction="#goToLogin" styleClass="bottom-link"/>
            </HBox>

        </VBox>
    </VBox>

</HBox>