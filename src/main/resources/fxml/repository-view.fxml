<?xml version="1.0" encoding="UTF-8"?>
<!-- repository-view.fxml -->

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<HBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.wig3003.multimedia.controller.RepositoryController"
      stylesheets="@../css/app.css"
      spacing="0">

    <!-- SIDE NAVIGATION BAR -->
    <fx:include fx:id="sideNavBar" source="side-nav-bar.fxml"/>

    <!-- MAIN CONTENT AREA -->
    <VBox fx:id="contentArea" styleClass="content-area" spacing="20" HBox.hgrow="ALWAYS">
        <padding>
            <Insets top="20" right="20" bottom="20" left="20"/>
        </padding>

        <Label text="Repository Module" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #5A3C2E;"/>
        <Label text="Photo library and management" styleClass="text-muted"/>
        
        <Separator/>
        
        <!-- WHITE CARD WRAPPER -->
        <VBox style="-fx-background-color: white; -fx-background-radius: 16;
                     -fx-border-radius: 16; -fx-border-color: #E8DDD5;
                     -fx-border-width: 1; -fx-effect: dropshadow(gaussian, #00000015, 12, 0, 0, 2);"
              VBox.vgrow="ALWAYS">

            <!-- Scrollable Image Grid -->
            <ScrollPane fx:id="imagePanel" fitToWidth="true" VBox.vgrow="ALWAYS"
                        style="-fx-background-color: transparent; -fx-background: transparent;">
                        <content>
                            <VBox>
                                <TilePane fx:id="imagesContainer" hgap="10" vgap="10"/>
                            </VBox>
                        </content>
            </ScrollPane>

            <padding><Insets top="24" right="28" bottom="24" left="28"/></padding>
            <Button fx:id="importButton" text="➕ Import Images" 
                                                maxWidth="Infinity"
                                                style="-fx-background-color: #5A3C2E; -fx-text-fill: white;
                                                    -fx-font-size: 14px; -fx-font-weight: bold;
                                                    -fx-background-radius: 10; -fx-padding: 13; -fx-cursor: hand;"/>
              
        </VBox>
    </VBox>

</HBox>
