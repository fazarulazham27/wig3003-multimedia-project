<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.wig3003.multimedia.controller.DipController"
            stylesheets="@/css/app.css" style="-fx-background-color: #F2E6D8;">

    <center>
        <VBox fx:id="contentArea"
              styleClass="dip-content"
              spacing="20"
              alignment="CENTER">

            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>

            <Label text="Edit Image" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #5A3C2E;"/>

            <!-- CENTER WRAPPER -->
            <VBox alignment="CENTER">

                <!-- MAIN CONTENT -->
                <HBox spacing="20"
                      alignment="TOP_CENTER">

                    <!-- LEFT: IMAGE -->
                    <VBox fx:id="imageContainer"
                          alignment="CENTER"
                          VBox.vgrow="ALWAYS"
                          minHeight="600"
                          prefHeight="600"
                          maxHeight="650">

                        <StackPane alignment="CENTER">

                            <ImageView fx:id="imageView"
                                       fitWidth="500"
                                       fitHeight="500"
                                       preserveRatio="true"/>

                        </StackPane>

                    </VBox>

                    <!-- RIGHT: CONTROLS -->
                    <VBox spacing="15"
                          prefWidth="500"
                          alignment="CENTER_LEFT">

                        <!-- CONTRAST -->
                        <HBox spacing="10">
                            <Label text="Contrast"
                                   alignment="CENTER"
                                   minWidth="120"
                                   prefWidth="120"
                                   maxWidth="120" 
                                   style ="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #5A3C2E;"/>

                            <Slider fx:id="contrastSlider"
                                    min="-1"
                                    max="1"
                                    HBox.hgrow="ALWAYS"
                                    maxWidth="Infinity" 
                                    styleClass = "slider"/>
                        </HBox>

                        <!-- BRIGHTNESS -->
                        <HBox spacing="10">
                            <Label text="Brightness"
                                   alignment="CENTER"
                                   minWidth="120"
                                   prefWidth="120"
                                   maxWidth="120"
                                   style ="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #5A3C2E;"/>

                            <Slider fx:id="brightnessSlider"
                                    min="-1"
                                    max="1"
                                    HBox.hgrow="ALWAYS"
                                    maxWidth="Infinity" 
                                    styleClass = "slider"/>
                        </HBox>

                        <!-- FRAME -->
                        <HBox spacing="10">
                            <Label text="Frame"
                                   alignment="CENTER"
                                   minWidth="120"
                                   prefWidth="120"
                                   maxWidth="120" 
                                   style ="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #5A3C2E;"/>

                            <Button text="Add/Remove Frame"
                                    onAction="#toggleFrame" 
                                    style="-fx-background-color: #D7A57B; -fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold;
                                            -fx-background-radius: 8; -fx-padding: 8; -fx-cursor: hand;" />

                            <Button text="Change Frame"
                                    onAction="#changeFrameStyle" 
                                    style="-fx-background-color: #D7A57B; -fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold;
                                            -fx-background-radius: 8; -fx-padding: 8; -fx-cursor: hand;" />
                        </HBox>

                        <!-- GRAYSCALE -->
                        <HBox spacing="10">
                            <Label text="Grayscale"
                                   alignment="CENTER"
                                   minWidth="120"
                                   prefWidth="120"
                                   maxWidth="120" 
                                   style ="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #5A3C2E;"/>

                            <Button text="Gray"
                                    onAction="#applyGrayscale"  
                                    style="-fx-background-color: #D7A57B; -fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold;
                                            -fx-background-radius: 8; -fx-padding: 8; -fx-cursor: hand;" />
                        </HBox>

                        <!-- TRANSFORM TITLE -->
                        <HBox alignment="CENTER"
                              HBox.hgrow="ALWAYS"
                              maxWidth="Infinity">

                            <Label text="Transform"
                                   maxWidth="Infinity"
                                   alignment="CENTER"
                                   HBox.hgrow="ALWAYS" 
                                   style ="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #5A3C2E;"/>

                        </HBox>

                        <!-- TRANSFORM BUTTONS -->
                        <HBox spacing="10" alignment="CENTER">
                            <Button text="Rotate"
                                    onAction="#rotateImage" 
                                    style="-fx-background-color: #D7A57B; -fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold;
                                            -fx-background-radius: 8; -fx-padding: 8; -fx-cursor: hand;" />

                            <Button text="Flip Horizontal"
                                    onAction="#flipHorizontal" 
                                    style="-fx-background-color: #D7A57B; -fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold;
                                            -fx-background-radius: 8; -fx-padding: 8; -fx-cursor: hand;" />

                            <Button text="Flip Vertical"
                                    onAction="#flipVertical" 
                                    style="-fx-background-color: #D7A57B; -fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold;
                                            -fx-background-radius: 8; -fx-padding: 8; -fx-cursor: hand;" />
                        </HBox>

                        <!-- OBJECT -->
                        <HBox alignment="CENTER"
                              HBox.hgrow="ALWAYS"
                              maxWidth="Infinity">

                            <Button text="Select Object"
                                    onAction="#openObjectSelection"
                                    HBox.hgrow="ALWAYS"
                                    maxWidth="Infinity" 
                                    style="-fx-background-color: #5A3C2E; -fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold;
                                            -fx-background-radius: 8; -fx-padding: 8; -fx-cursor: hand;" />
                        </HBox>

                        <!-- SAVE / REVERT -->
                        <HBox spacing="10" alignment="CENTER">
                            <Button text="Revert"
                                    onAction="#revertImage" 
                                    style="-fx-background-color: #5A3C2E; -fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold;
                                            -fx-background-radius: 8; -fx-padding: 8; -fx-cursor: hand;" />

                            <Button text="Save Edit"
                                    onAction="#saveEditedImage" 
                                    style="-fx-background-color: #5A3C2E; -fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold;
                                            -fx-background-radius: 8; -fx-padding: 8; -fx-cursor: hand;" />
                        </HBox>

                        <!-- BACK -->
                        <HBox alignment="CENTER">
                            <Button text="Back"
                                    onAction="#goBack" 
                                    style="-fx-background-color: #5A3C2E; -fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold;
                                            -fx-background-radius: 8; -fx-padding: 8; -fx-cursor: hand;" />
                        </HBox>

                    </VBox>

                </HBox>

            </VBox>

        </VBox>
    </center>

</BorderPane>