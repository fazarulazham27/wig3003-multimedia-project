<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<HBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.wig3003.multimedia.controller.LoginController"
      stylesheets="@../css/auth.css,@../css/app.css">

    <VBox styleClass="left-panel" alignment="CENTER" spacing="15" prefWidth="700">
        <Label text="📷" styleClass="logo-icon"/>
        <Label text="PhotoManager" styleClass="logo-title"/>
        <Label text="Organize, manage, and cherish your memories" styleClass="logo-subtitle"/>
    </VBox>

    <VBox styleClass="right-panel" alignment="CENTER" spacing="18" prefWidth="900">

        <VBox styleClass="auth-card" spacing="8" alignment="TOP_LEFT">

            <padding>
                <Insets top="25" right="30" bottom="25" left="30"/>
            </padding>

            <Label text="Welcome Back" styleClass="card-title"/>
            <Label text="Sign in to continue to PhotoManager" styleClass="card-subtitle"/>

            <!-- EMAIL -->
            <Label text="Email" styleClass="field-label"/>

            <HBox fx:id="emailBox" styleClass="input-box" alignment="CENTER_LEFT" spacing="10">
                <Label text="✉" styleClass="input-icon"/>
                <TextField fx:id="emailField"
                           promptText="Enter your email"
                           HBox.hgrow="ALWAYS"
                           styleClass="text-input"/>
            </HBox>

            <Label fx:id="emailError"
                   text=""
                   styleClass="error-text"
                   visible="false"
                   managed="false"/>

            <!-- PASSWORD -->
            <Label text="Password" styleClass="field-label"/>

            <HBox fx:id="passwordBox" styleClass="input-box" alignment="CENTER_LEFT" spacing="10">
                <Label text="🔒" styleClass="input-icon"/>
                <PasswordField fx:id="passwordField"
                               promptText="Enter your password"
                               HBox.hgrow="ALWAYS"
                               styleClass="text-input"/>
            </HBox>

            <Label fx:id="passwordError"
                   text=""
                   styleClass="error-text"
                   visible="false"
                   managed="false"/>

            <Button text="Login"
                    onAction="#login"
                    styleClass="primary-btn"
                    maxWidth="Infinity"/>

            <Label fx:id="statusLabel" styleClass="status-text"/>

            <HBox alignment="CENTER" spacing="5">
                <Label text="Don't have an account?" styleClass="bottom-text"/>
                <Hyperlink text="Sign Up" onAction="#goToSignup" styleClass="bottom-link"/>
            </HBox>

        </VBox>
    </VBox>

</HBox>