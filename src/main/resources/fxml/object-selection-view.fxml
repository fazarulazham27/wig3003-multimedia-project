<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.canvas.Canvas?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.wig3003.multimedia.controller.ObjectSelectionController"
            stylesheets="@../css/app.css" 
            style="-fx-background-color: #F2E6D8;">

    <!-- TITLE AREA (TOP) -->
    <top>
        <VBox spacing="5"
              alignment="CENTER">

            <padding>
                <Insets top="15" right="20" bottom="10" left="20"/>
            </padding>

            <Label text="Object Selection Tool"
                   style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #5A3C2E;"/>

            <Label text="Draw line on object to select region by color similarity" style = "-fx-text-fill: #5A3C2E;"/>
        </VBox>
    </top>

    <!-- MAIN CONTENT -->
    <center>
        <VBox spacing="20"
              alignment="CENTER">

            <padding>
                <Insets top="10" right="20" bottom="10" left="20"/>
            </padding>

            <!-- IMAGE + RESULT -->
            <HBox spacing="30" alignment="CENTER">

                <!-- ORIGINAL + CANVAS -->
                <StackPane prefWidth="450"
                           prefHeight="450"
                           style="-fx-border-color: lightgray;">

                    <ImageView fx:id="originalView"
                               fitWidth="450"
                               fitHeight="450"
                               preserveRatio="true"/>

                    <Canvas fx:id="overlayCanvas"
                            width="450"
                            height="450"/>
                </StackPane>

                <!-- RESULT -->
                <StackPane prefWidth="450"
                           prefHeight="450"
                           style="-fx-border-color: lightgray;">

                    <ImageView fx:id="resultView"
                               fitWidth="450"
                               fitHeight="450"
                               preserveRatio="true"/>
                </StackPane>

            </HBox>

            <!-- BUTTONS -->
            <HBox spacing="10"
                  alignment="CENTER">

                <Button text="Clear"
                        onAction="#clearBrush"
                        style="-fx-background-color: #D7A57B; -fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold;
                                            -fx-background-radius: 8; -fx-padding: 8; -fx-cursor: hand;"/>

                <Button text="Save Object"
                        onAction="#saveObject"
                        style="-fx-background-color: #5A3C2E; -fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold;
                                            -fx-background-radius: 8; -fx-padding: 8; -fx-cursor: hand;"/>

            </HBox>

            <!-- BACK BUTTON SEPARATE (better UX) -->
            <HBox alignment="CENTER">
                <Button text="Back"
                        onAction="#goBack" 
                        style="-fx-background-color: #5A3C2E; -fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold;
                                            -fx-background-radius: 8; -fx-padding: 8; -fx-cursor: hand;"/>
            </HBox>

        </VBox>
    </center>

</BorderPane>